{
  "buildCommand": "npm run build && cp -r public/uploads/. dist/uploads/",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/uploads/(.*)", "destination": "/uploads/$1" },
    { "source": "/api/(.*)", "destination": "/server.cjs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
